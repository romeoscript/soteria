{
  "name": "soteria",
  "private": true,
  "version": "0.1.0",
  "description": "Solana privacy toolkit — ZK selective disclosure, stealth receiving, confidential amounts.",
  "workspaces": ["packages/*", "server", "app"],
  "scripts": {
    "build:sdk": "npm -w packages/sdk run build",
    "build:app": "npm -w @soteria/app run build",
    "build": "npm run build:sdk && npm run build:app",
    "dev:server": "npm -w server run dev",
    "dev:app": "npm -w app run dev",
    "setup": "bash scripts/setup.sh",
    "setup:pool": "bash scripts/setup-pool.sh",
    "gen:idl": "node scripts/gen-idl.js > target/idl/soteria_verifier.json && node scripts/gen-idl.js > server/src/idl/soteria_verifier.json",
    "anchor:build": "anchor build",
    "anchor:test": "anchor test"
  },
  "overrides": {
    "@solana/kit": "6.10.0"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "0.30.1",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "chai": "^4.4.1",
    "circomlib": "^2.0.5",
    "circomlibjs": "^0.1.7",
    "mocha": "^10.3.0",
    "snarkjs": "^0.7.5",
    "ts-mocha": "^10.0.0",
    "typescript": "^5.6.3"
  }
}
