{
  "name": "@soteria1/sdk",
  "version": "0.1.1",
  "description": "Soteria privacy SDK for Solana: hidden-amount shielded payments, ZK selective disclosure, stealth addresses, confidential amounts.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "keywords": [
    "solana",
    "privacy",
    "zk",
    "zero-knowledge",
    "shielded",
    "payments",
    "groth16",
    "circom",
    "stealth",
    "confidential"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/romeoscript/soteria.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/romeoscript/soteria#readme",
  "bugs": {
    "url": "https://github.com/romeoscript/soteria/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@noble/curves": "^1.6.0",
    "@noble/hashes": "^1.5.0",
    "@solana-program/token-2022": "^0.12.0",
    "@solana-program/zk-elgamal-proof": "^0.2.0",
    "@solana/kit": "^6.10.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/sysvars": "^5.5.1",
    "@solana/web3.js": "^1.95.4",
    "@solana/zk-sdk": "^0.4.2",
    "circomlibjs": "^0.1.7",
    "snarkjs": "^0.7.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
