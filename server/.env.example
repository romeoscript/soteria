# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8787
LOG_LEVEL=info

# CORS allowlist: comma-separated origins, or * for any.
CORS_ORIGINS=*

# Guards admin / mutating routes (x-api-key header), min 16 chars.
# Leave unset to DISABLE those routes (they return 503).
ADMIN_API_KEY=

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Persistence ──────────────────────────────────────────────────────────
# Postgres connection string. Unset = non-durable in-memory storage (dev only).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/soteria

# ── Solana ───────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.devnet.solana.com
SOTERIA_PROGRAM_ID=9HNLpUVFX61pX759oy1vuMMwQaQaGnK9KgMyhTrDrRGs

# base58-encoded secret keys. Each unset = that capability disabled:
#   RELAYER   → POST /relay/verify   (submits verify_proof, pays fees)
#   AUTHORITY → POST /groups, /sets/:id/publish (create_group, publish_root)
RELAYER_SECRET_KEY=
AUTHORITY_SECRET_KEY=
